APP_NAME=MedicalHub
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# CORS: comma-separated origins (e.g. http://localhost:4200,http://127.0.0.1:4200)
CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Optimization & Performance
CACHE_DASHBOARD_ENABLED=true
CACHE_DASHBOARD_TTL=120
CACHE_PATIENT_LIST_TTL=60
CACHE_DOCTOR_LIST_TTL=60
CACHE_FINANCIAL_TTL=300
RESPONSE_COMPRESSION=true
HTTP_CACHE_TTL=300
ENABLE_ETAG=true

# Security
BRUTE_FORCE_THROTTLE=5
BRUTE_FORCE_DECAY=1
API_RATE_LIMIT=60
API_RATE_LIMIT_DECAY=1
FORCE_HTTPS=false

# Upload
MAX_UPLOAD_SIZE=5120
IMAGE_QUALITY=80
THUMBNAIL_SIZE=300

# Clinova AI UI Engine (règles + cache ; Pexels optionnel — requêtes génériques uniquement)
AI_UI_ENABLED=true
AI_UI_CACHE_TTL=300
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=
